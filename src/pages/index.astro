---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

// This dynamically fetches your markdown posts and sorts them by date
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
		<style is:global>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			:root {
				--ink: #0f0e0c; --ink-muted: #6b6860; --ink-faint: #b8b5ae;
				--bg: #faf9f6; --bg-warm: #f3f0e8; --accent: #1a3a5c;
				--accent-light: #e8eef5; --rule: rgba(0,0,0,0.1);
				--serif: 'EB Garamond', Georgia, serif; --mono: 'DM Mono', monospace;
			}
			body { font-family: var(--serif); background: var(--bg); color: var(--ink); font-size: 17px; line-height: 1.7; min-height: 100vh; }

			.hero { max-width: 780px; margin: 0 auto; padding: 5.5rem 2rem 4rem; border-bottom: 0.5px solid var(--rule); }
			.hero-eyebrow { font-family: var(--mono); font-size: 11px; font-weight: 300; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 1.4rem; }
			.hero h1 { font-size: clamp(2.4rem, 5.5vw, 3.8rem); font-weight: 400; line-height: 1.1; letter-spacing: -0.02em; color: var(--ink); }
			.hero h1 em { font-style: italic; color: var(--ink-muted); }
			.hero-bio { font-size: 1.05rem; color: var(--ink-muted); line-height: 1.75; max-width: 620px; margin: 1.6rem 0 2.4rem; font-style: italic; }
			.hero-bio strong { font-style: normal; color: var(--ink); font-weight: 500; }
			.hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }
			.btn-primary { padding: 10px 24px; background: var(--accent); color: white; border: none; border-radius: 40px; font-family: var(--mono); font-size: 12px; font-weight: 300; letter-spacing: 0.06em; text-decoration: none; display: inline-block; transition: opacity 0.15s; }
			.btn-primary:hover { opacity: 0.82; }
			.btn-ghost { padding: 10px 24px; background: transparent; color: var(--ink-muted); border: 0.5px solid var(--rule); border-radius: 40px; font-family: var(--mono); font-size: 12px; font-weight: 300; letter-spacing: 0.06em; text-decoration: none; display: inline-block; transition: all 0.15s; }
			.btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

			.section { max-width: 780px; margin: 0 auto; padding: 3rem 2rem; }
			.section-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 2rem; }
			.section-title { font-size: 0.8rem; font-family: var(--mono); font-weight: 300; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-faint); }
			.see-all { font-family: var(--mono); font-size: 11px; color: var(--accent); text-decoration: none; letter-spacing: 0.04em; }
			.see-all:hover { text-decoration: underline; }

			.posts-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 1px; background: var(--rule); border: 0.5px solid var(--rule); border-radius: 12px; overflow: hidden; }
			.post-card { display: block; text-decoration: none; background: var(--bg); padding: 1.8rem; transition: background 0.15s; cursor: pointer; }
			.post-card:hover { background: var(--accent-light); }
			.post-card.featured { grid-row: span 2; display: flex; flex-direction: column; justify-content: flex-end; background: var(--accent); color: white; min-height: 300px; padding: 2.2rem; }
			.post-card.featured:hover { background: #142e4a; }
			.post-tag { font-family: var(--mono); font-size: 10px; font-weight: 300; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 0.8rem; }
			.post-card.featured .post-tag { color: rgba(255,255,255,0.45); }
			.post-title { font-size: 1.2rem; font-weight: 400; line-height: 1.3; color: var(--ink); margin-bottom: 0.6rem; font-style: italic; margin-top: 0; }
			.post-card.featured .post-title { font-size: 1.55rem; color: white; }
			.post-excerpt { font-size: 0.86rem; color: var(--ink-muted); line-height: 1.6; font-family: var(--mono); font-weight: 300; font-style: normal; margin: 0; }
			.post-card.featured .post-excerpt { color: rgba(255,255,255,0.6); }

			@media (max-width: 720px) {
				.posts-grid { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Hello, I'm<br><em>Khushi Raj.</em></h1>
				<p class="hero-bio">
					A fourth year BS-MS undergraduate majoring in <strong>Physics</strong> from the <strong>Indian Institute of Science Education and Research (IISER) Berhampur</strong>. My research interests are in <strong>Quantum Information Theory</strong> and <strong>Quantum Foundations</strong>.
				</p>
				<div class="hero-btns">
					<a href="/blog" class="btn-primary">Start Reading</a>
					<a href="/cv" class="btn-ghost">View CV</a>
				</div>
			</section>

			<section class="section">
				<div class="section-header">
					<span class="section-title">Recent from the journal</span>
					<a href="/blog" class="see-all">All entries →</a>
				</div>
				<div class="posts-grid">
					{posts.map((post, index) => (
						/* Safely grabs either the new or old Astro ID, just like the journal page! */
						<a href={`/blog/${post.slug || post.id}/`} class={`post-card ${index === 0 ? 'featured' : ''}`}>
							<p class="post-tag">
								{index === 0 ? 'Featured · ' : ''}
								{post.data.pubDate.toLocaleDateString('en-us', { month: 'short', year: 'numeric' })}
							</p>
							<h2 class="post-title" style={index !== 0 ? "font-size:1.05rem" : ""}>{post.data.title}</h2>
							<p class="post-excerpt" style={index !== 0 ? "margin-top: 0.5rem;" : ""}>{post.data.description}</p>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>