---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style is:global>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			:root {
				--ink: #0f0e0c; --ink-muted: #6b6860; --ink-faint: #b8b5ae;
				--bg: #faf9f6; --accent: #1a3a5c; --accent-light: #e8eef5; --rule: rgba(0,0,0,0.1);
				--serif: 'EB Garamond', Georgia, serif; --mono: 'DM Mono', monospace;
			}
			body { font-family: var(--serif); background: var(--bg); color: var(--ink); line-height: 1.7; }

			.section { max-width: 780px; margin: 0 auto; padding: 3rem 2rem; }
			.page-hero { max-width: 780px; margin: 0 auto; padding: 4rem 2rem 3rem; border-bottom: 0.5px solid var(--rule); }
			.page-hero h1 { font-size: 2.5rem; font-weight: 400; margin-bottom: 0.5rem; }
			.page-hero h1 em { font-style: italic; color: var(--ink-muted); }
			.page-hero p { font-style: italic; color: var(--ink-muted); font-size: 1.1rem; margin: 0; }

			/* This styles the list to look like cards */
			.journal-list { display: flex; flex-direction: column; gap: 1px; background: var(--rule); border: 0.5px solid var(--rule); border-radius: 12px; overflow: hidden; margin-top: 2rem; }

			/* This makes the whole card clickable and styled */
			.journal-entry { text-decoration: none; background: var(--bg); padding: 1.6rem 1.8rem; display: flex; gap: 2rem; transition: background 0.15s; color: inherit; cursor: pointer; display: block; }
			.journal-entry:hover { background: var(--accent-light); }

			.entry-date { font-family: var(--mono); font-size: 13px; color: var(--ink-faint); margin-bottom: 0.5rem; display: block; }
			.entry-title { font-size: 1.4rem; font-style: italic; color: var(--ink); margin-bottom: 0.5rem; margin-top: 0; font-weight: 500; }
			.entry-excerpt { font-size: 1rem; color: var(--ink-muted); margin: 0; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-hero">
				<h1>Research <em>Journal</em></h1>
				<p>A living record of research notes, paper reflections, and explorations of ideas encountered along the way.</p>
			</div>

			<section class="section">
				<div class="journal-list">
					{posts.map((post) => (
						/* Safely grabs either the new or old Astro ID so links actually work */
						<a href={`/blog/${post.slug || post.id}/`} class="journal-entry">
							<span class="entry-date">
								{post.data.pubDate.toLocaleDateString('en-us', { month: 'short', year: 'numeric' })}
							</span>
							<div class="entry-body">
								<h3 class="entry-title">{post.data.title}</h3>
								<p class="entry-excerpt">{post.data.description}</p>
							</div>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>