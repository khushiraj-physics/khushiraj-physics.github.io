---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`CV | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
		<style is:global>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			:root {
				--ink: #0f0e0c; --ink-muted: #6b6860; --ink-faint: #b8b5ae;
				--bg: #faf9f6; --accent: #1a3a5c; --accent-light: #e8eef5; --rule: rgba(0,0,0,0.1);
				--serif: 'EB Garamond', Georgia, serif; --mono: 'DM Mono', monospace;
			}
			body { font-family: var(--serif); background: var(--bg); color: var(--ink); line-height: 1.7; }

			.page-hero { max-width: 780px; margin: 0 auto; padding: 4rem 2rem 2rem; }
			.page-hero h1 { font-size: 2.5rem; font-weight: 400; margin-bottom: 0.5rem; }
			.page-hero h1 em { font-style: italic; color: var(--ink-muted); }
			.page-hero p { font-style: italic; color: var(--ink-muted); font-size: 1.1rem; margin: 0; }

			.cv-container { max-width: 780px; margin: 0 auto; padding: 0 2rem 4rem; display: flex; flex-direction: column; gap: 1.5rem; }

			/* Styled Download Button */
			.download-bar { display: flex; justify-content: flex-start; }
			.btn-primary { padding: 12px 26px; background: var(--accent); color: white; border: none; border-radius: 40px; font-family: var(--mono); font-size: 12px; font-weight: 300; letter-spacing: 0.06em; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: opacity 0.15s; cursor: pointer; }
			.btn-primary:hover { opacity: 0.85; }

			/* Interactive PDF View Frame */
			.cv-preview-box { width: 100%; height: 850px; border: 0.5px solid var(--rule); border-radius: 12px; overflow: hidden; background: white; box-shadow: 0 4px 20px rgba(0,0,0,0.02); }
			.cv-iframe { width: 100%; height: 100%; border: none; }

			@media (max-width: 720px) {
				.cv-preview-box { height: 550px; } /* Makes it fit beautifully on phone screens too */
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-hero">
				<h1>Curriculum <em>Vitae</em></h1>
				<p>View or download the full academic record.</p>
			</div>

			<div class="cv-container">
				<div class="download-bar">
					<a href="/Khushi_Raj_CV.pdf" download="Khushi_Raj_CV.pdf" class="btn-primary">
						Download PDF Copy ↓
					</a>
				</div>

				<div class="cv-preview-box">
					<iframe
						src="/Khushi_Raj_CV.pdf#toolbar=1"
						class="cv-iframe"
						title="Khushi Raj CV Preview"
					></iframe>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>