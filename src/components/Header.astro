---
const { pathname } = Astro.url;
// Cleans up trailing slashes so matching works perfectly
const currentPath = pathname.replace(/\/$/, "");
---

<nav>
  <div class="nav-pill">
    <a href="/" class={currentPath === "" ? "active" : ""}>Home</a>
    <a href="/blog" class={currentPath.startsWith("/blog") ? "active" : ""}>Research Journal</a>
    <a href="/cv" class={currentPath === "/cv" ? "active" : ""}>CV</a>
    <a href="/contact" class={currentPath === "/contact" ? "active" : ""}>Contact</a>
  </div>
</nav>