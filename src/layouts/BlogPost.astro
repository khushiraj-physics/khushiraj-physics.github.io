---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
		<style is:global>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			:root {
				--ink: #0f0e0c; --ink-muted: #6b6860; --ink-faint: #b8b5ae;
				--bg: #faf9f6; --bg-warm: #f3f0e8; --accent: #1a3a5c;
				--accent-light: #e8eef5; --rule: rgba(0,0,0,0.1);
				--serif: 'EB Garamond', Georgia, serif; --mono: 'DM Mono', monospace;
			}
			body { font-family: var(--serif); background: var(--bg); color: var(--ink); font-size: 17px; line-height: 1.7; min-height: 100vh; }

			nav {
				position: sticky; top: 0; z-index: 100;
				background: rgba(250,249,246,0.94); backdrop-filter: blur(8px);
				display: flex; align-items: center; justify-content: center; padding: 14px 2rem;
				border-bottom: 0.5px solid var(--rule);
			}
			.nav-pill { display: flex; align-items: center; background: white; border: 0.5px solid rgba(0,0,0,0.12); border-radius: 50px; padding: 4px; gap: 2px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
			.nav-pill a { display: block; padding: 7px 18px; font-family: var(--mono); font-size: 12px; font-weight: 300; letter-spacing: 0.03em; color: #888; text-decoration: none; border-radius: 40px; transition: all 0.18s; }
			.nav-pill a:hover { color: var(--ink); background: rgba(0,0,0,0.04); }
			.nav-pill a.active { background: #1a1a1a; color: white; }

			.blog-layout-wrapper {
				max-width: 1100px;
				margin: 0 auto;
				padding: 4rem 2rem;
				display: grid;
				grid-template-columns: 1fr;
				gap: 3rem;
			}

			@media (min-width: 1000px) {
				.blog-layout-wrapper {
					grid-template-columns: 680px 320px;
					padding-right: 0;
				}
			}

			.article-container { max-width: 680px; }
			.meta { font-family: var(--mono); font-size: 11px; color: var(--ink-muted); text-transform: uppercase; margin-bottom: 1rem; }
			h1 { font-size: 2.5rem; font-weight: 400; font-style: italic; line-height: 1.2; margin-bottom: 2rem; color: var(--ink); }
			.content :global(p) { margin-bottom: 1.5rem; }

			.define-term {
				border-bottom: 1px dashed var(--accent);
				color: var(--accent);
				cursor: help;
				transition: background 0.2s;
				padding: 0 2px;
			}
			.define-term:hover, .define-term.active-term {
				background: var(--accent-light);
			}

			.margin-sidebar {
				display: none;
			}

			@media (min-width: 1000px) {
				.margin-sidebar {
					display: block;
					position: sticky;
					top: 120px;
					height: max-content;
					padding-left: 1.5rem;
					border-left: 0.5px solid var(--rule);
				}
			}

			.margin-box {
				font-family: var(--mono);
				font-size: 13px;
				line-height: 1.6;
				color: var(--ink-muted);
				background: var(--bg-warm);
				padding: 1.2rem;
				border-radius: 8px;
				border: 0.5px solid var(--rule);
				opacity: 0;
				transform: translateY(10px);
				transition: all 0.25s ease;
				visibility: hidden; /* Kept completely hidden until clicked */
			}

			.margin-box.visible {
				opacity: 1;
				transform: translateY(0);
				visibility: visible;
			}

			.margin-box strong {
				color: var(--ink);
				display: block;
				margin-bottom: 0.4rem;
				font-family: var(--serif);
				font-size: 15px;
			}

			@media (max-width: 999px) {
				.margin-sidebar {
					display: block;
					position: fixed;
					bottom: 0; left: 0; right: 0;
					z-index: 200;
					padding: 0;
					border: none;
				}
				.margin-box {
					margin: 1rem;
					box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
					background: white;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<div class="blog-layout-wrapper">
			<main class="article-container">
				<article>
					<div class="meta">
						{pubDate.toLocaleDateString('en-us', { month: 'short', day: 'numeric', year: 'numeric' })}
					</div>
					<h1>{title}</h1>
					<div class="content">
						<slot />
					</div>
				</article>
			</main>

			<aside class="margin-sidebar">
				<div id="definition-box" class="margin-box">
					<strong id="definition-title"></strong>
					<span id="definition-text"></span>
				</div>
			</aside>
		</div>

		<Footer />

		<script>
			const terms = document.querySelectorAll('.define-term');
			const defBox = document.getElementById('definition-box');
			const defTitle = document.getElementById('definition-title');
			const defText = document.getElementById('definition-text');

			terms.forEach(term => {
				term.addEventListener('click', (e) => {
					e.preventDefault();

					terms.forEach(t => t.classList.remove('active-term'));
					term.classList.add('active-term');

					const word = term.textContent;
					const definition = term.getAttribute('data-def');

					if (defBox && defTitle && defText) {
						defBox.classList.remove('visible');

						setTimeout(() => {
							defTitle.textContent = word;
							defText.textContent = definition;
							defBox.addModule ? null : defBox.classList.add('visible');
						}, 150);
					}
				});
			});

			document.addEventListener('click', (e) => {
				if (!(e.target as HTMLElement).classList.contains('define-term')) {
					defBox?.classList.remove('visible');
					terms.forEach(t => t.classList.remove('active-term'));
				}
			});
		</script>
	</body>
</html>